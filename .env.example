# Supabase (opcional). Sem essas variaveis o app funciona normalmente,
# so esconde o login e o historico.
# Pegue esses valores em: Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nome do bucket de Storage criado pelo supabase/schema.sql
NEXT_PUBLIC_SUPABASE_BUCKET=bubbleblaster
